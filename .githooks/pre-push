#!/usr/bin/env bash

set -e

echo "Running backend checks before push..."

docker compose exec -T backend ruff check .
docker compose exec -T backend ruff format --check .
docker compose exec -T backend python manage.py check
docker compose exec -T backend coverage run \
  --source=. \
  --omit="*/migrations/*,*/tests/*,manage.py,config/*" \
  manage.py test

docker compose exec -T backend coverage report -m

echo "Backend checks passed. Continuing push."